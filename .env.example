# ===== Client (exposed to browser via NEXT_PUBLIC_*) =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Server (never expose) =====
# Supabase service role — bypasses RLS, server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API — required for agents
ANTHROPIC_API_KEY=sk-ant-...

# Stripe billing
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Directfy (WhatsApp)
DIRECTFY_API_URL=https://api.directfy.com
# REQUIRED in production. If unset, /api/webhooks/directfy returns 503.
DIRECTFY_WEBHOOK_SECRET=replace-with-random-hex-32

# Background jobs (BullMQ)
REDIS_URL=redis://localhost:6379

# Runtime
NODE_ENV=development

# ===== Optional observability =====
# Sentry DSN (client + server share the same DSN; public)
NEXT_PUBLIC_SENTRY_DSN=
# Log level for structured logger (debug | info | warn | error)
LOG_LEVEL=info

# ===== Cron =====
# Shared secret for Vercel cron endpoints (x-cron-secret header)
CRON_SECRET=replace-with-random-hex-32
